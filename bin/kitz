#!/usr/bin/env sh
# kitz — capture Claude Code artifacts (commands / skills / plugins) on the fly.
#
# Multi-call: symlink as cmdz|sklz|plgz to preset the artifact type.
# Pure logic is split from IO so the core is testable without a TTY
# (source with KITZ_SOURCED=1 to load functions without running main).
set -eu

KITZ_VERSION="0.1.0"

# ---------------------------------------------------------------------------
# tiny output helpers
# ---------------------------------------------------------------------------
err()  { printf 'kitz: %s\n' "$1" >&2; }
die()  { err "$1"; exit "${2:-1}"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$1"; }
info() { printf '\033[2m%s\033[0m\n' "$1"; }

# ---------------------------------------------------------------------------
# pure helpers (deterministic, side-effect free)
# ---------------------------------------------------------------------------

# slugify <str> -> kebab-case; keeps '/' for command namespacing.
slugify() {
  printf '%s' "$1" |
    tr '[:upper:]' '[:lower:]' |
    sed -e 's#[^a-z0-9/]\{1,\}#-#g' \
        -e 's#-\{1,\}#-#g' \
        -e 's#/-#/#g' -e 's#-/#/#g' \
        -e 's#^-##' -e 's#-$##' \
        -e 's#^/##' -e 's#/$##'
}

# titlecase <slug> -> "Title Case" for headings.
titlecase() {
  printf '%s' "$1" | tr '/-' '  ' |
    awk '{for(i=1;i<=NF;i++)$i=toupper(substr($i,1,1)) substr($i,2)}1'
}

# find_up <marker> <start-dir> -> nearest ancestor (incl. start) holding marker.
find_up() {
  _marker="$1"; _dir="$2"
  while [ -n "$_dir" ] && [ "$_dir" != "/" ]; do
    if [ -e "$_dir/$_marker" ]; then printf '%s' "$_dir"; return 0; fi
    _dir="$(dirname "$_dir")"
  done
  if [ -e "/$_marker" ]; then printf '/'; return 0; fi
  return 1
}

# resolve_scope <scope> <start-dir> -> base dir whose .claude/ we target.
resolve_scope() {
  _scope="$1"; _start="${2:-$PWD}"
  case "$_scope" in
    user) printf '%s' "$HOME" ;;
    here) printf '%s' "$_start" ;;
    project)
      # Nearest real project root by marker.
      if _p="$(find_up .git "$_start")"; then :
      elif _p="$(find_up package.json "$_start")"; then :
      elif _p="$(find_up .claude "$_start")"; then :
      else _p="$_start"; fi
      # Never $HOME — that's the 'user' scope, not a project. (e.g. dotfiles
      # repos / ~/.claude would otherwise hijack 'project' from any subdir.)
      if [ "$_p" = "$HOME" ]; then _p="$_start"; fi
      printf '%s' "$_p" ;;
    workspace)
      for _m in pnpm-workspace.yaml turbo.json lerna.json nx.json go.work; do
        if _b="$(find_up "$_m" "$_start")"; then printf '%s' "$_b"; return 0; fi
      done
      _base="$_start"; _d="$_start"
      while [ "$_d" != "/" ]; do
        if [ -e "$_d/.git" ]; then _base="$_d"; fi
        _d="$(dirname "$_d")"
      done
      printf '%s' "$_base" ;;
    *) die "unknown scope: $_scope" ;;
  esac
}

# target_path <type> <base> <name> -> primary file path to write.
target_path() {
  case "$1" in
    command) printf '%s/.claude/commands/%s.md' "$2" "$3" ;;
    skill)   printf '%s/.claude/skills/%s/SKILL.md' "$2" "$3" ;;
    plugin)  printf '%s/.claude/plugins/%s/.claude-plugin/plugin.json' "$2" "$3" ;;
    *) die "unknown type: $1" ;;
  esac
}

render_command() {
  _name="$1"; _desc="$2"; _args="$3"; _tools="$4"; _model="$5"; _body="$6"
  printf -- '---\n'
  printf 'description: %s\n' "${_desc:-TODO: one-line description}"
  if [ -n "$_args" ];  then printf 'argument-hint: %s\n' "$_args"; fi
  if [ -n "$_tools" ]; then printf 'allowed-tools: %s\n' "$_tools"; fi
  if [ -n "$_model" ]; then printf 'model: %s\n' "$_model"; fi
  printf -- '---\n\n'
  printf '%s\n' "${_body:-<!-- Prompt for Claude. \$ARGUMENTS, \$1..\$9, !bash, @file all work. -->}"
}

render_skill() {
  _name="$1"; _desc="$2"; _tools="$3"; _body="$4"
  printf -- '---\n'
  printf 'name: %s\n' "$_name"
  printf 'description: %s\n' "${_desc:-TODO: one-line description (drives auto-trigger)}"
  if [ -n "$_tools" ]; then printf 'allowed-tools: %s\n' "$_tools"; fi
  printf -- '---\n\n'
  printf '# %s\n\n' "$(titlecase "$_name")"
  printf '%s\n' "${_body:-Describe what this skill does and when Claude should use it.}"
}

# plugin_manifest <name> <desc> -> plugin.json (desc quotes escaped).
plugin_manifest() {
  _name="$1"; _desc="$(printf '%s' "${2:-TODO: one-line description}" | sed 's/"/\\"/g')"
  printf '{\n  "name": "%s",\n  "version": "0.1.0",\n  "description": "%s"\n}\n' \
    "$_name" "$_desc"
}

render() {
  case "$1" in
    command) shift; render_command "$@" ;;
    skill)   shift; render_skill "$1" "$2" "$4" "$6" ;;  # name desc tools body
    plugin)  shift; plugin_manifest "$1" "$2" ;;
    *) die "unknown type: $1" ;;
  esac
}

# ---------------------------------------------------------------------------
# IO (mocked / skipped in tests)
# ---------------------------------------------------------------------------
have() { command -v "$1" >/dev/null 2>&1; }

# _ver_ge_030 <version> : true if a "MAJOR.MINOR[.PATCH]" string is >= 0.30 (pure).
_ver_ge_030() {
  case "$1" in ''|*[!0-9.]*) return 1 ;; esac
  _maj="${1%%.*}"; _rest="${1#*.}"; _min="${_rest%%.*}"
  [ "${_maj:-0}" -gt 0 ] && return 0
  [ "${_min:-0}" -ge 30 ]
}

# fzf_confirms: true if this fzf supports the change-header action (>= 0.30, 2022).
# Older builds error on an unknown action, so the "✓ copied…" confirmation is
# only wired in when the version clears the bar — otherwise it degrades to silent.
fzf_confirms() { _ver_ge_030 "$(fzf --version 2>/dev/null | awk '{print $1}')"; }

# clipboard_cmd -> the platform "copy stdin to clipboard" command (empty if none).
clipboard_cmd() {
  if   have pbcopy;   then printf 'pbcopy'
  elif have wl-copy;  then printf 'wl-copy'
  elif have xclip;    then printf 'xclip -selection clipboard'
  elif have xsel;     then printf 'xsel --clipboard --input'
  elif have clip.exe; then printf 'clip.exe'
  fi
}

# remove_target <type> <listed-path> -> the path to delete (pure).
# The picker lists a file, but skills/plugins live in a directory we remove whole.
remove_target() {
  case "$1" in
    skill)  dirname "$2" ;;                              # …/skills/<name>/SKILL.md -> …/<name>
    plugin) _d="$2"; printf '%s' "${_d%/.claude-plugin/plugin.json}" ;;
    *)      printf '%s' "$2" ;;                          # command: the file itself
  esac
}

# do_remove <type> <listed-path>: delete the artifact, no prompt (testable).
do_remove() {
  _tgt="$(remove_target "$1" "$2")"
  [ -n "$_tgt" ] && [ -e "$_tgt" ] || return 0
  rm -rf -- "$_tgt"
}

# internal_copy <path>: copy a file's contents to the clipboard (picker ctrl-y).
internal_copy() {
  _clip="${KITZ_CLIP:-$(clipboard_cmd)}"
  [ -n "$_clip" ] && [ -f "$1" ] || return 0
  # word-split $_clip on purpose (e.g. "xclip -selection clipboard").
  # shellcheck disable=SC2086
  $_clip < "$1"
}

# internal_reveal <path>: show the file in the OS file manager (picker ctrl-o).
# macOS reveals+selects it in Finder; elsewhere we open its containing folder.
internal_reveal() {
  [ -e "$1" ] || return 0
  if [ -n "${KITZ_REVEAL:-}" ]; then
    # override for tests / custom file managers; receives the file path.
    # shellcheck disable=SC2086
    $KITZ_REVEAL "$1"
  elif have open;         then open -R "$1"                              # macOS Finder
  elif have xdg-open;     then xdg-open "$(dirname "$1")" >/dev/null 2>&1 # Linux
  elif have explorer.exe; then explorer.exe "$(dirname "$1")" >/dev/null 2>&1 || true
  fi
}

# internal_delete <type> <path>: confirm on the tty, then do_remove (picker ctrl-x).
internal_delete() {
  _tgt="$(remove_target "$1" "$2")"
  [ -n "$_tgt" ] && [ -e "$_tgt" ] || return 0
  printf 'delete %s ? [y/N] ' "$_tgt" > /dev/tty 2>/dev/null || return 0
  IFS= read -r _ans < /dev/tty 2>/dev/null || return 0
  case "$_ans" in y|Y|yes|YES) do_remove "$1" "$2" ;; esac
}

# build_scope_menu <start> -> "scope<TAB>base<TAB>state" lines.
build_scope_menu() {
  for _s in project workspace here user; do
    _base="$(resolve_scope "$_s" "$1")"
    if [ -d "$_base/.claude" ]; then _state="exists"; else _state="will create"; fi
    printf '%s\t%s\t%s\n' "$_s" "$_base" "$_state"
  done
}

pick_scope() {
  build_scope_menu "$1" |
    fzf --prompt='scope ▸ ' --height=40% --reverse --no-multi \
        --delimiter='\t' --with-nth='1,2,3' |
    cut -f1
}

# scan_type <type> <base> -> "name<TAB>path" for existing artifacts under one base.
scan_type() {
  case "$1" in
    command) _glob="$2/.claude/commands" ; _suffix=".md" ;;
    skill)   _glob="$2/.claude/skills"   ; _suffix="/SKILL.md" ;;
    plugin)  _glob="$2/.claude/plugins"  ; _suffix="/.claude-plugin/plugin.json" ;;
    *) return 0 ;;
  esac
  [ -d "$_glob" ] || return 0
  if [ "$1" = command ]; then
    find "$_glob" -type f -name '*.md' 2>/dev/null | while IFS= read -r f; do
      _n="${f#"$_glob"/}"; _n="${_n%.md}"; printf '%s\t%s\n' "$_n" "$f"
    done
  else
    find "$_glob" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | while IFS= read -r d; do
      printf '%s\t%s%s\n' "$(basename "$d")" "$d" "$_suffix"
    done
  fi
}

# list_artifacts <type> <start> -> "name<TAB>path" for existing artifacts.
list_artifacts() {
  for _s in project workspace user here; do
    scan_type "$1" "$(resolve_scope "$_s" "${2:-$PWD}")"
  done | sort -u
}

# dedup_by_path: keep the first row per unique path (field 4). First-seen wins,
# so the earliest scope in list_all's priority order labels a shared location.
dedup_by_path() { awk -F'\t' '!seen[$4]++'; }

# list_all <start> -> "type<TAB>scope<TAB>name<TAB>path" across every type/scope.
# Powers the bare-`kitz` home dashboard. Names sort last so their varied length
# never misaligns the columns before them.
list_all() {
  _start="${1:-$PWD}"
  for _t in command skill plugin; do
    for _s in user project workspace here; do
      scan_type "$_t" "$(resolve_scope "$_s" "$_start")" |
        while IFS="$(printf '\t')" read -r _n _p; do
          printf '%s\t%s\t%s\t%s\n' "$_t" "$_s" "$_n" "$_p"
        done
    done
  done | dedup_by_path | sort
}

# pick_name <type> <start>: sets globals RESULT_NAME and RESULT_PATH.
# RESULT_PATH non-empty => user chose an existing artifact to edit.
pick_name() {
  RESULT_NAME=""; RESULT_PATH=""
  # $f is set and expanded inside the fzf-spawned preview shell, not here.
  # shellcheck disable=SC2016
  _preview='f={2}; if command -v bat >/dev/null 2>&1; then bat --style=plain --color=always "$f" 2>/dev/null; else cat "$f" 2>/dev/null; fi'
  # ctrl-y/ctrl-o are silent, so each chains change-header to flash a "✓ copied…"
  # confirmation (prepended to the hint line); ctrl-x's reload is its own feedback.
  # (Bare c/x can't be used — typing filters the list in fzf.) $_self re-invokes
  # this same engine; $1 (the type) drives whole-dir removal for skills/plugins.
  _self="${KITZ_SELF:-kitz}"
  _hints='enter edit · ctrl-y copy · ctrl-o reveal · ctrl-x delete'
  _cy="ctrl-y:execute-silent($_self __copy {2})"
  _co="ctrl-o:execute-silent($_self __reveal {2})"
  if fzf_confirms; then
    _cy="$_cy+change-header(✓ copied {1} to clipboard  ·  $_hints)"
    _co="$_co+change-header(✓ revealed {1} in Finder  ·  $_hints)"
  fi
  _out="$(list_artifacts "$1" "$2" |
    fzf --prompt="$1 name ▸ " --height=70% --reverse --no-multi --print-query \
        --delimiter='\t' --with-nth=1 \
        --header="$_hints" \
        --bind="$_cy" --bind="$_co" \
        --bind="ctrl-x:execute($_self __delete $1 {2})+reload($_self --list $1)" \
        --preview="$_preview" --preview-window='right,60%' || true)"
  # line1 = typed query; line2 (if any) = selected "name<TAB>path"
  _query="$(printf '%s\n' "$_out" | sed -n '1p')"
  _sel="$(printf '%s\n' "$_out" | sed -n '2p')"
  if [ -n "$_sel" ]; then
    RESULT_NAME="$(printf '%s' "$_sel" | cut -f1)"
    RESULT_PATH="$(printf '%s' "$_sel" | cut -f2)"
  else
    RESULT_NAME="$(slugify "$_query")"
  fi
}

# choose_type -> command|skill|plugin, picked via fzf (empty if cancelled).
choose_type() {
  printf 'command\nskill\nplugin\n' |
    fzf --prompt='new ▸ ' --height=20% --reverse --no-multi --header='what to create'
}

# home_tui: the bare-`kitz` cross-type dashboard. Browses every artifact with a
# preview; enter edits, ctrl-y copies, ctrl-x deletes (reload). ctrl-n / ctrl-g
# accept out to create: they set TYPE (+NAME/GENERATE) and RETURN so main creates.
# Any other exit (edit an existing, or cancel) is terminal — it exits the process.
home_tui() {
  _self="${KITZ_SELF:-kitz}"
  # shellcheck disable=SC2016
  _preview='f={4}; if command -v bat >/dev/null 2>&1; then bat --style=plain --color=always "$f" 2>/dev/null; else cat "$f" 2>/dev/null; fi'
  # ctrl-y/ctrl-o flash a "✓ copied…" confirmation via change-header ({3}=name),
  # where supported; ctrl-x's reload is its own feedback.
  _hints='enter edit · ctrl-y copy · ctrl-o reveal · ctrl-x delete · ctrl-n new · ctrl-g draft'
  _cy="ctrl-y:execute-silent($_self __copy {4})"
  _co="ctrl-o:execute-silent($_self __reveal {4})"
  if fzf_confirms; then
    _cy="$_cy+change-header(✓ copied {3} to clipboard  ·  $_hints)"
    _co="$_co+change-header(✓ revealed {3} in Finder  ·  $_hints)"
  fi
  _out="$(list_all "$PWD" |
    fzf --prompt='kitz ▸ ' --height=90% --reverse --no-multi --print-query \
        --expect=ctrl-n,ctrl-g \
        --delimiter='\t' --with-nth='1,2,3' \
        --header="$_hints" \
        --bind="$_cy" --bind="$_co" \
        --bind="ctrl-x:execute($_self __delete {1} {4})+reload($_self __lsall)" \
        --preview="$_preview" --preview-window='right,55%' || true)"
  # With --print-query + --expect: line1=query, line2=key (empty on Enter), line3=row.
  _query="$(printf '%s\n' "$_out" | sed -n '1p')"
  _key="$(printf '%s\n'   "$_out" | sed -n '2p')"
  _sel="$(printf '%s\n'   "$_out" | sed -n '3p')"
  case "$_key" in
    ctrl-n) TYPE="$(choose_type)"; [ -n "$TYPE" ] || exit 0
            NAME="$_query"; return 0 ;;
    ctrl-g) TYPE="$(choose_type)"; [ -n "$TYPE" ] || exit 0
            NAME="$_query"; GENERATE=1; return 0 ;;
    *)  # plain Enter (edit the highlighted row) or cancel
        if [ -n "$_sel" ]; then
          _path="$(printf '%s' "$_sel" | cut -f4)"
          info "editing $(printf '%s' "$_sel" | cut -f1): $_path"
          open_editor "$_path"
          ok "saved $_path"
        fi
        exit 0 ;;
  esac
}

open_editor() {
  _ed="${VISUAL:-${EDITOR:-vi}}"
  "$_ed" "$1"
}

# write_artifact <path> <content>: honours DRY_RUN / FORCE.
write_artifact() {
  _path="$1"; _content="$2"
  if [ "${DRY_RUN:-0}" = 1 ]; then
    printf '── dry-run ──────────────────────────────\npath: %s\n\n%s\n' "$_path" "$_content"
    return 0
  fi
  if [ -e "$_path" ] && [ "${FORCE:-0}" != 1 ]; then
    die "refusing to overwrite $_path (use -f to force)" 3
  fi
  mkdir -p "$(dirname "$_path")"
  printf '%s\n' "$_content" > "$_path"
}

# scaffold_plugin <base> <name>: create commands/ and skills/ dirs.
scaffold_plugin() {
  [ "${DRY_RUN:-0}" = 1 ] && return 0
  mkdir -p "$1/.claude/plugins/$2/commands" "$1/.claude/plugins/$2/skills"
}

# invoke_hint <type> <name> -> how to call it from Claude.
invoke_hint() {
  case "$1" in
    command) printf '/%s' "$(printf '%s' "$2" | tr '/' ':')" ;;
    skill)   printf 'skill: %s' "$2" ;;
    plugin)  printf 'plugin: %s' "$2" ;;
  esac
}

# ---------------------------------------------------------------------------
# ghostwriter — draft the artifact body with Claude (claude -p, headless)
# ---------------------------------------------------------------------------

# gen_prompt <type> <name> <intent> <desc> <args> -> meta-prompt (pure).
# Literal $ARGUMENTS/$1 in the prompt text are intentional (instructions to the
# model), not shell expansions.
# shellcheck disable=SC2016
gen_prompt() {
  _t="$1"; _n="$2"; _intent="$3"; _d="$4"; _a="$5"
  printf 'You are generating a Claude Code %s file. Output ONLY the raw file content — no commentary, no surrounding code fences.\n\n' "$_t"
  case "$_t" in
    command)
      printf 'Create a slash-command named "%s".\nPurpose: %s\n\nRequirements:\n' "$_n" "$_intent"
      printf -- '- Start with YAML frontmatter: a one-line `description:` and an `argument-hint:`.\n'
      printf -- '- Then write the body as a direct, specific prompt addressed to Claude that accomplishes the purpose.\n'
      printf -- '- Use $ARGUMENTS (and $1, $2 … if several inputs make sense) where the user input belongs.\n'
      printf -- '- Prefer concrete, evidence-oriented steps over vague instructions.\n' ;;
    skill)
      printf 'Create a SKILL.md for a skill named "%s".\nPurpose: %s\n\nRequirements:\n' "$_n" "$_intent"
      printf -- '- YAML frontmatter with `name: %s` and a one-line `description:` that makes clear WHEN Claude should auto-trigger it.\n' "$_n"
      printf -- '- Then a top-level `# Title` heading followed by the skill instructions.\n' ;;
  esac
  if [ -n "$_d" ]; then printf -- '- The description should be: %s\n' "$_d"; fi
  if [ -n "$_a" ]; then printf -- '- The argument-hint should be: %s\n' "$_a"; fi
  printf '\nOutput ONLY the file content.\n'
}

# revise_prompt <type> <name> <intent> <prior> <feedback> -> revision prompt (pure).
revise_prompt() {
  _t="$1"; _n="$2"; _intent="$3"; _prior="$4"; _fb="$5"
  printf 'You previously drafted this Claude Code %s file (named "%s", purpose: %s):\n\n' "$_t" "$_n" "$_intent"
  printf '%s\n\n' "$_prior"
  printf 'Revise it per this feedback: %s\n\n' "$_fb"
  printf 'Output ONLY the revised raw file content — no commentary, no surrounding code fences.\n'
}

# strip_outer_fence: drop a ```fence wrapping the WHOLE file; keep inner fences.
strip_outer_fence() {
  awk '{l[NR]=$0} END{
    s=1; e=NR
    if (NR>=2 && l[1] ~ /^```/) { s=2; if (l[NR] ~ /^```[ \t]*$/) e=NR-1 }
    for(i=s;i<=e;i++) print l[i]
  }'
}

# run_claude <prompt> -> model completion with any outer code-fence stripped.
# Generator is overridable via $KITZ_CLAUDE_BIN (tests point it at a stub).
# Forbid all tools so it's a fast single-shot completion, not an agentic run
# (plan-mode made it emit a plan + go slow; no-tools keeps it ~10s & raw).
run_claude() {
  _bin="${KITZ_CLAUDE_BIN:-claude}"
  have "$_bin" || die "--generate needs the '$_bin' CLI on PATH"
  _notools="Bash,Read,Write,Edit,Glob,Grep,WebFetch,WebSearch,Task,TodoWrite,NotebookEdit"
  if [ -n "${GEN_MODEL:-}" ]; then
    "$_bin" -p "$1" --output-format text --model "$GEN_MODEL" --disallowedTools "$_notools"
  else
    "$_bin" -p "$1" --output-format text --disallowedTools "$_notools"
  fi | strip_outer_fence
}

# generate_body <type> <name> <intent> <desc> <args> -> drafted file content.
generate_body() { run_claude "$(gen_prompt "$@")"; }

# regenerate_body <type> <name> <intent> <prior> <feedback> -> revised content.
regenerate_body() { run_claude "$(revise_prompt "$@")"; }

# refine_loop: interactive accept/regenerate/tweak menu. Mutates global CONTENT,
# sets global FINALIZE to save|editor. Returns non-zero if the user cancels.
refine_loop() {
  _tmp="$(mktemp)"; _ret=1; FINALIZE=cancel
  while :; do
    printf '%s\n' "$CONTENT" > "$_tmp"
    # shellcheck disable=SC2016
    _prev='if command -v bat >/dev/null 2>&1; then bat --style=plain --color=always '"$_tmp"'; else cat '"$_tmp"'; fi'
    _choice="$(printf 'save\nedit by hand\nregenerate\ntweak with a note\ncancel\n' |
      fzf --prompt='draft ▸ ' --height=90% --reverse --no-multi \
          --preview="$_prev" --preview-window='right,62%')"
    case "$_choice" in
      save)        FINALIZE=save;   _ret=0; break ;;
      'edit by hand') FINALIZE=editor; _ret=0; break ;;
      regenerate)
        printf '✦ regenerating…\n' >&2
        CONTENT="$(generate_body "$TYPE" "$NAME" "$INTENT" "$DESC" "$ARGS")" ;;
      'tweak with a note')
        _fb="$(prompt_line 'what to change')"
        [ -n "$_fb" ] || continue
        printf '✦ revising…\n' >&2
        CONTENT="$(regenerate_body "$TYPE" "$NAME" "$INTENT" "$CONTENT" "$_fb")" ;;
      *) _ret=1; break ;;
    esac
  done
  rm -f "$_tmp"
  return "$_ret"
}

# prompt_line <label> -> a single line of free-text input.
prompt_line() {
  if have fzf; then
    printf '' | fzf --print-query --prompt="$1 ▸ " --height=15% --reverse | head -1
  else
    printf '%s: ' "$1" >&2; IFS= read -r _l; printf '%s' "$_l"
  fi
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
# _check_dep <bin> <what> <required|optional>
_check_dep() {
  if have "$1"; then printf '  ✓ %-7s %s\n' "$1" "$2"
  elif [ "$3" = required ]; then printf '  ✗ %-7s %s — REQUIRED\n' "$1" "$2"
  else printf '  · %-7s %s — optional\n' "$1" "$2"; fi
}

# run_doctor: report deps, editor, model, and the scopes resolved from $PWD.
run_doctor() {
  printf 'kitz %s — doctor\n\ndependencies:\n' "$KITZ_VERSION"
  _check_dep fzf    "interactive pickers" required
  _check_dep bat    "preview in pickers"  optional
  _check_dep claude "ghostwriter (-g)"    optional
  _ed="${VISUAL:-${EDITOR:-}}"
  if [ -n "$_ed" ] && have "$_ed"; then printf '  ✓ editor   %s\n' "$_ed"
  else printf '  · editor   none set (falls back to vi)\n'; fi
  printf '\ngeneration model: %s\n\nscopes resolved from %s:\n' "${GEN_MODEL:-<claude default>}" "$PWD"
  build_scope_menu "$PWD" | while IFS="$(printf '\t')" read -r _s _base _state; do
    printf '  %-9s %s/.claude (%s)\n' "$_s" "$_base" "$_state"
  done
}

usage() {
  cat <<'EOF'
kitz — capture Claude Code artifacts on the fly

USAGE
  cmdz [name] [options]            # slash command
  sklz [name] [options]            # skill
  plgz [name] [options]            # plugin
  kitz                             # home dashboard: browse/edit/copy/delete/new
  kitz --doctor | --help | --version    # umbrella (non-interactive: prints help)

OPTIONS
  -t, --type <command|skill|plugin>
  -s, --scope <user|project|workspace|here>
  -d, --dir <path>          target <path>/.claude
  -g, --generate            ghostwrite the body with Claude (claude -p)
  -i, --intent <text>       what it should do (the generation brief)
      --revise <note>       draft, then revise once with this note (with -g)
      --gen-model <model>   model for --generate (default claude-sonnet-4-6)
  -m, --message <text>      body (skips editor)
  -M, --message-file <path> body read from a file (skips editor)
  -D, --description <text>  frontmatter description
  -a, --args <hint>         argument-hint (commands)
      --tools <csv>         allowed-tools
      --model <model>       model frontmatter
  -e, --edit                open editor even with -m
  -y, --yes                 non-interactive (defaults, no prompts)
  -f, --force               overwrite if exists
  -n, --dry-run             print path + content, write nothing
  -o, --open                reopen in $EDITOR after writing
  -l, --list                list artifacts of this type
      --doctor              check deps, editor, model, and resolved scopes
  -h, --help / -v, --version
EOF
}

default_type_from_name() {
  case "$(basename "$1")" in
    cmdz) printf command ;;
    sklz) printf skill ;;
    plgz) printf plugin ;;
    *) printf '' ;;
  esac
}

main() {
  # Internal re-entry from the fzf picker (see pick_name). Handled before normal
  # parsing so the multi-call basename never matters here.
  case "${1:-}" in
    __copy)   internal_copy "${2:-}"; exit 0 ;;
    __delete) internal_delete "${2:-}" "${3:-}"; exit 0 ;;
    __reveal) internal_reveal "${2:-}"; exit 0 ;;
    __lsall)  list_all "$PWD"; exit 0 ;;
  esac

  # Absolute path to this engine, so the picker's binds can re-invoke it.
  KITZ_SELF="$0"
  case "$KITZ_SELF" in
    /*) ;;
    */*) KITZ_SELF="$PWD/$KITZ_SELF" ;;
    *)   KITZ_SELF="$(command -v "$KITZ_SELF" 2>/dev/null || printf '%s' "$KITZ_SELF")" ;;
  esac
  export KITZ_SELF

  TYPE="$(default_type_from_name "$0")"
  NAME=""; SCOPE=""; DIR=""; MESSAGE=""; DESC=""; ARGS=""; TOOLS=""; MODEL=""
  EDIT=0; YES=0; FORCE=0; DRY_RUN=0; OPEN=0; LIST=0; DOCTOR=0
  GENERATE=0; INTENT=""; GEN_MODEL="${KITZ_GEN_MODEL:-claude-sonnet-4-6}"
  REVISE=""; FINALIZE=editor

  while [ $# -gt 0 ]; do
    case "$1" in
      command|skill|plugin)
        if [ -z "$TYPE" ]; then TYPE="$1"; else NAME="$1"; fi ;;
      -t|--type) TYPE="$2"; shift ;;
      -s|--scope) SCOPE="$2"; shift ;;
      -d|--dir) DIR="$2"; shift ;;
      -g|--generate) GENERATE=1 ;;
      -i|--intent) INTENT="$2"; shift ;;
      --revise) REVISE="$2"; shift ;;
      --gen-model) GEN_MODEL="$2"; shift ;;
      -m|--message) MESSAGE="$2"; shift ;;
      -M|--message-file)
        [ -f "$2" ] || die "message-file not found: $2"
        MESSAGE="$(cat "$2")"; shift ;;
      -D|--description) DESC="$2"; shift ;;
      -a|--args) ARGS="$2"; shift ;;
      --tools) TOOLS="$2"; shift ;;
      --model) MODEL="$2"; shift ;;
      -e|--edit) EDIT=1 ;;
      -y|--yes) YES=1 ;;
      -f|--force) FORCE=1 ;;
      -n|--dry-run) DRY_RUN=1 ;;
      -o|--open) OPEN=1 ;;
      -l|--list) LIST=1 ;;
      --doctor) DOCTOR=1 ;;
      -h|--help) usage; exit 0 ;;
      -v|--version) printf 'kitz %s\n' "$KITZ_VERSION"; exit 0 ;;
      -*) die "unknown option: $1" 2 ;;
      *) if [ -z "$NAME" ]; then NAME="$1"; else die "unexpected argument: $1" 2; fi ;;
    esac
    shift
  done

  if [ "$DOCTOR" = 1 ]; then run_doctor; exit 0; fi

  if [ "$LIST" = 1 ]; then
    [ -n "$TYPE" ] || die "list needs a type (use cmdz/sklz/plgz or --type)"
    list_artifacts "$TYPE" "$PWD"; exit 0
  fi

  # type — set by the command name (cmdz/sklz/plgz) or --type. Bare `kitz` on an
  # interactive terminal opens the cross-type home dashboard; in a script/pipe (or
  # without fzf) it stays a help/umbrella command, so nothing shelling out breaks.
  if [ -z "$TYPE" ]; then
    if [ -z "$NAME" ] && [ -t 0 ] && [ -t 1 ] && have fzf; then
      home_tui   # edits/copies/deletes and exits, or sets TYPE(+NAME/GENERATE) to create
    fi
    if [ -z "$TYPE" ]; then
      if [ -z "$NAME" ]; then usage; exit 0; fi
      die "no type — use cmdz/sklz/plgz, or 'kitz <command|skill|plugin> <name>' / --type"
    fi
  fi

  # name (+ possible edit-existing)
  RESULT_PATH=""
  if [ -z "$NAME" ]; then
    [ "$YES" = 1 ] && die "name required in --yes mode"
    have fzf || die "fzf required for interactive name pick (or pass a name)"
    pick_name "$TYPE" "$PWD"
    NAME="$RESULT_NAME"
  else
    NAME="$(slugify "$NAME")"
  fi
  [ -n "$NAME" ] || die "empty name"

  # edit an existing artifact in place
  if [ -n "$RESULT_PATH" ]; then
    info "editing existing $TYPE: $RESULT_PATH"
    open_editor "$RESULT_PATH"
    ok "saved $RESULT_PATH"
    exit 0
  fi

  # base dir
  if [ -n "$DIR" ]; then
    BASE="$DIR"
  elif [ -n "$SCOPE" ]; then
    BASE="$(resolve_scope "$SCOPE" "$PWD")"
  elif [ "$YES" = 1 ]; then
    BASE="$(resolve_scope project "$PWD")"
  else
    have fzf || die "fzf required for interactive scope pick (or pass --scope/--dir)"
    SCOPE="$(pick_scope "$PWD")"; [ -n "$SCOPE" ] || die "no scope selected"
    BASE="$(resolve_scope "$SCOPE" "$PWD")"
  fi

  PATH_OUT="$(target_path "$TYPE" "$BASE" "$NAME")"

  # --generate is for prose artifacts; plugins are structural.
  if [ "$GENERATE" = 1 ] && [ "$TYPE" = plugin ]; then
    err "note: --generate isn't supported for plugins; using template"
    GENERATE=0
  fi

  # content: render from fields, or ghostwrite with Claude.
  if [ "$GENERATE" = 1 ]; then
    [ -n "$INTENT" ] || INTENT="$MESSAGE"
    [ -n "$INTENT" ] || INTENT="$DESC"
    if [ -z "$INTENT" ] && [ "$YES" != 1 ]; then INTENT="$(prompt_line 'what should it do?')"; fi
    [ -n "$INTENT" ] || INTENT="$(printf '%s' "$NAME" | tr '/-' '  ')"
    printf '✦ drafting %s "%s" with Claude…\n' "$TYPE" "$NAME" >&2
    CONTENT="$(generate_body "$TYPE" "$NAME" "$INTENT" "$DESC" "$ARGS")"
    [ -n "$CONTENT" ] || die "generation returned empty"
    # one-shot non-interactive revision
    if [ -n "$REVISE" ]; then
      printf '✦ revising per note…\n' >&2
      CONTENT="$(regenerate_body "$TYPE" "$NAME" "$INTENT" "$CONTENT" "$REVISE")"
      [ -n "$CONTENT" ] || die "revision returned empty"
    fi
    # interactive refine loop (accept / regenerate / tweak), with live preview
    if [ "$YES" != 1 ] && [ "$DRY_RUN" != 1 ] && have fzf; then
      refine_loop || { info "cancelled"; exit 0; }
    fi
  else
    CONTENT="$(render "$TYPE" "$NAME" "$DESC" "$ARGS" "$TOOLS" "$MODEL" "$MESSAGE")"
  fi

  # finalize in editor (interactive) unless the draft was accepted as-is (save).
  if [ "$YES" != 1 ] && [ "$DRY_RUN" != 1 ] && [ "$FINALIZE" = editor ]; then
    if [ "$GENERATE" = 1 ] || [ "$EDIT" = 1 ] || [ -z "$MESSAGE" ]; then
      have "${VISUAL:-${EDITOR:-vi}}" || die "no editor found (set \$EDITOR)"
      _tmpdir="$(mktemp -d)"; _ext=md; [ "$TYPE" = plugin ] && _ext=json
      _draft="$_tmpdir/draft.$_ext"
      printf '%s\n' "$CONTENT" > "$_draft"
      open_editor "$_draft"
      CONTENT="$(cat "$_draft")"
      rm -rf "$_tmpdir"
    fi
  fi

  write_artifact "$PATH_OUT" "$CONTENT"
  if [ "$TYPE" = plugin ]; then scaffold_plugin "$BASE" "$NAME"; fi

  if [ "$DRY_RUN" != 1 ]; then
    ok "wrote $PATH_OUT"
    info "invoke with: $(invoke_hint "$TYPE" "$NAME")"
    if [ "$OPEN" = 1 ]; then open_editor "$PATH_OUT"; fi
  fi
  return 0
}

# Sourcing guard: `KITZ_SOURCED=1 . kitz` loads functions without running main.
if [ "${KITZ_SOURCED:-0}" != "1" ]; then
  main "$@"
fi
